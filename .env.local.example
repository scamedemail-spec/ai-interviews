# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to ".env.local" and fill in your key. ".env.local" is gitignored,
# so your key never gets committed.
#
#   cp .env.local.example .env.local
#
# Then paste your Anthropic API key below (no quotes, no spaces).
# Get a key at: https://console.anthropic.com/  → "API Keys"
# ─────────────────────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=

# Optional: override the model. Defaults to claude-sonnet-4-6 if left unset.
# ANTHROPIC_MODEL=claude-sonnet-4-6
